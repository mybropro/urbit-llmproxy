// Single-ship install: shim + node both on your ship.
// Shim's `node` config defaults to `our.bowl`, so requests stay local.
digraph single_ship {
  rankdir=LR;
  bgcolor="white";
  fontname="Helvetica";
  node [fontname="Helvetica", fontsize=11, shape=box, style="rounded,filled"];
  edge [fontname="Helvetica", fontsize=10];

  client [label="OpenAI client\n(curl, Continue.dev, Open WebUI)",
          shape=ellipse, fillcolor="#e8f1fb", color="#4a7bb5"];

  subgraph cluster_ship {
    label="Your ship";
    fontname="Helvetica";
    fontsize=12;
    style="rounded,filled";
    fillcolor="#f7f7f5";
    color="#cccccc";

    shim [label="%llmproxy-shim\nEyre HTTP gateway",
          fillcolor="#fff7d8", color="#c9a000"];
    nodea [label="%llmproxy-node\nrouter to Ollama",
           fillcolor="#fff7d8", color="#c9a000"];

    shim -> nodea [label="Gall poke\n+ subscription", color="#888"];
  }

  ollama [label="Ollama / vLLM / llama.cpp\nlocalhost:11434",
          shape=cylinder, fillcolor="#fde8e8", color="#b54a4a"];

  client -> shim [label="POST /llmproxy/v1/chat/completions",
                  color="#4a7bb5"];
  nodea -> ollama [label="HTTP via %iris",
                   color="#b54a4a"];
}
