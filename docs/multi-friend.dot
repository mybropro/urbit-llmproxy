// One node, many friends — and each friend points multiple
// OpenAI-compatible clients at their single shim.
digraph multi_friend {
  rankdir=LR;
  bgcolor="white";
  fontname="Helvetica";
  node [fontname="Helvetica", fontsize=11, shape=box, style="rounded,filled"];
  edge [fontname="Helvetica", fontsize=10];

  subgraph cluster_friend1 {
    label="~friend-a";
    fontname="Helvetica";
    fontsize=11;
    style="rounded,filled";
    fillcolor="#f7f7f5";
    color="#cccccc";
    fa_app1 [label="Continue.dev", shape=ellipse, fillcolor="#e8f1fb", color="#4a7bb5"];
    fa_app2 [label="OpenCode", shape=ellipse, fillcolor="#e8f1fb", color="#4a7bb5"];
    fa_app3 [label="curl", shape=ellipse, fillcolor="#e8f1fb", color="#4a7bb5"];
    fa_shim [label="%llmproxy-shim", fillcolor="#fff7d8", color="#c9a000"];
    fa_app1 -> fa_shim [color="#4a7bb5"];
    fa_app2 -> fa_shim [color="#4a7bb5"];
    fa_app3 -> fa_shim [color="#4a7bb5"];
  }

  subgraph cluster_friend2 {
    label="~friend-b";
    fontname="Helvetica";
    fontsize=11;
    style="rounded,filled";
    fillcolor="#f7f7f5";
    color="#cccccc";
    fb_app1 [label="AtomicChat", shape=ellipse, fillcolor="#e8f1fb", color="#4a7bb5"];
    fb_app2 [label="Open WebUI", shape=ellipse, fillcolor="#e8f1fb", color="#4a7bb5"];
    fb_shim [label="%llmproxy-shim", fillcolor="#fff7d8", color="#c9a000"];
    fb_app1 -> fb_shim [color="#4a7bb5"];
    fb_app2 -> fb_shim [color="#4a7bb5"];
  }

  subgraph cluster_friend3 {
    label="~friend-c";
    fontname="Helvetica";
    fontsize=11;
    style="rounded,filled";
    fillcolor="#f7f7f5";
    color="#cccccc";
    fc_app1 [label="shell script", shape=ellipse, fillcolor="#e8f1fb", color="#4a7bb5"];
    fc_app2 [label="Continue.dev", shape=ellipse, fillcolor="#e8f1fb", color="#4a7bb5"];
    fc_shim [label="%llmproxy-shim", fillcolor="#fff7d8", color="#c9a000"];
    fc_app1 -> fc_shim [color="#4a7bb5"];
    fc_app2 -> fc_shim [color="#4a7bb5"];
  }

  subgraph cluster_publisher {
    label="friend hosting models";
    fontname="Helvetica";
    fontsize=12;
    style="rounded,filled";
    fillcolor="#f7f7f5";
    color="#cccccc";
    pub_node [label="%llmproxy-node", fillcolor="#fff7d8", color="#c9a000"];
  }

  ollama [label="Ollama / vLLM",
          shape=cylinder, fillcolor="#fde8e8", color="#b54a4a"];

  fa_shim -> pub_node [label="Ames", color="#3aa37a", penwidth=2];
  fb_shim -> pub_node [label="Ames", color="#3aa37a", penwidth=2];
  fc_shim -> pub_node [label="Ames", color="#3aa37a", penwidth=2];
  pub_node -> ollama [label="HTTP via %iris", color="#b54a4a"];
}
