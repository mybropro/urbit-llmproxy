// Two-ship deployment: publisher with GPU runs the node;
// friend installs the desk and points their shim at the publisher.
// Curl on the friend's machine never leaves their localhost.
digraph two_ship {
  rankdir=LR;
  bgcolor="white";
  fontname="Helvetica";
  node [fontname="Helvetica", fontsize=11, shape=box, style="rounded,filled"];
  edge [fontname="Helvetica", fontsize=10];

  curl [label="curl / Continue.dev",
        shape=ellipse, fillcolor="#e8f1fb", color="#4a7bb5"];

  subgraph cluster_friend {
    label="Friend's ship (~friend)";
    fontname="Helvetica";
    fontsize=12;
    style="rounded,filled";
    fillcolor="#f7f7f5";
    color="#cccccc";

    friend_shim [label="%llmproxy-shim\nnode = ~publisher",
                 fillcolor="#fff7d8", color="#c9a000"];
  }

  subgraph cluster_publisher {
    label="Publisher's ship (~publisher)";
    fontname="Helvetica";
    fontsize=12;
    style="rounded,filled";
    fillcolor="#f7f7f5";
    color="#cccccc";

    pub_node [label="%llmproxy-node",
              fillcolor="#fff7d8", color="#c9a000"];
  }

  ollama [label="Publisher's Ollama\n(GPU machine)",
          shape=cylinder, fillcolor="#fde8e8", color="#b54a4a"];

  curl -> friend_shim [label="POST /llmproxy/v1/chat/completions\nlocalhost",
                       color="#4a7bb5"];
  friend_shim -> pub_node [label="poke + facts\nover Ames",
                            color="#3aa37a", penwidth=2];
  pub_node -> ollama [label="HTTP via %iris",
                      color="#b54a4a"];
}
